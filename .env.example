TOKEN=
CLIENT_ID=
PAYMENT_MODE=mock
TURBOFY_API_URL=https://api.turbofypay.com
TURBOFY_CLIENT_ID=
TURBOFY_CLIENT_SECRET=
PAYOUT_STATUS_DELAY_MS=2000
# Taxas de depósitos novos: 2,5% Turbofy + 0,5% Hydra Systems
TURBOFY_DEPOSIT_FEE_PERCENT=2.5
HYDRA_DEPOSIT_FEE_PERCENT=0.5
HYDRA_ADMIN_WALLET_USER_ID=1484834490378485760
PAYOUT_STATUS_ATTEMPTS=30
PAYOUT_STATUS_INTERVAL_MS=3000
PAYOUT_RECONCILE_INTERVAL_MS=30000

# Consulta rápida de payouts pendentes (milissegundos)
PAYOUT_RECONCILE_INTERVAL_MS=5000

# Proteção da API: após chave inválida ou pagamento recusado
PIX_ERROR_COOLDOWN_MS=60000

# Dados exibidos no comprovante escrito (opcional)
HYDRA_PAYER_NAME=Nome do titular da conta Turbofy
HYDRA_PAYER_DOCUMENT=00000000000
HYDRA_PAYER_INSTITUTION=TurbofyPay

# Hydra Systems — perfil e canal privado
HYDRA_MAIN_GUILD_ID=1524282646778085407
HYDRA_PRIVATE_CATEGORY_ID=1526865968222044180
HYDRA_ADMIN_ROLE_ID=1526866107976126485
HYDRA_LOG_CHANNEL_ID=1526866030255673434
HYDRA_BRAND_NAME=Hydra Systems

# Opcional: somente se a Turbofy não aceitar client_id/client_secret no endpoint de comprovante.
# Nunca envie esse token ao GitHub. Tokens de sessão podem expirar.
# TURBOFY_RECEIPT_BEARER_TOKEN=

# Comprovantes oficiais usam TURBOFY_CLIENT_ID e TURBOFY_CLIENT_SECRET
# com assinatura HMAC no endpoint /v1/receipts/transactions/{id}.
